PORT=5000

# Set to true when MySQL is unavailable (e.g. Vercel demo). Login uses bridge credentials in src/routes/auth.js.
# DISABLE_DB=true

DB_SERVER=localhost
DB_PORT=3306
DB_NAME=schoolmini
DB_USER=root
DB_PASSWORD=your_mysql_password

# Evaluation mode restrictions
APP_MODE=evaluation
EVAL_EXPIRES_AT=2026-12-31
EVAL_MAX_STUDENTS=20
EVAL_MAX_TASKS=50

JWT_SECRET=replace_me_with_a_long_random_string

# Admin credentials (simple env-based login)
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=admin123

# Optional: if set, takes precedence over ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=$2a$10$...
